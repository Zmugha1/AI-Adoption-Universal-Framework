{
  "version": "1.0",
  "description": "MLDLC Risk Matrix - RED/YELLOW/GREEN Classification",
  "risk_levels": {
    "RED": {
      "name": "High Risk",
      "score_range": [9, 12],
      "color": "#DC2626",
      "characteristics": [
        "Production deployment",
        "Customer-facing changes",
        "Data privacy implications",
        "Financial impact > $10K",
        "Regulatory compliance required"
      ],
      "requirements": [
        "Explicit approval required from stakeholders",
        "Full documentation mandatory",
        "Security review required",
        "Rollback plan required",
        "24-hour observation period post-deployment"
      ],
      "approvers": ["CTO", "Data Protection Officer", "Legal"]
    },
    "YELLOW": {
      "name": "Medium Risk",
      "score_range": [5, 8],
      "color": "#F59E0B",
      "characteristics": [
        "Staging deployment",
        "Internal tool changes",
        "Data quality improvements",
        "Financial impact $1K-$10K",
        "Process modifications"
      ],
      "requirements": [
        "Manager review required",
        "Documentation recommended",
        "Testing required",
        "Monitoring required"
      ],
      "approvers": ["Team Lead", "Project Manager"]
    },
    "GREEN": {
      "name": "Low Risk",
      "score_range": [1, 4],
      "color": "#10B981",
      "characteristics": [
        "Development environment",
        "Documentation updates",
        "Test additions",
        "Financial impact < $1K",
        "No customer impact"
      ],
      "requirements": [
        "Standard process",
        "Basic documentation",
        "Self-review acceptable"
      ],
      "approvers": ["Developer"]
    }
  },
  "scoring": {
    "scope": {"production": 3, "staging": 2, "development": 1},
    "data_sensitivity": {"high": 3, "medium": 2, "low": 1},
    "financial_impact": {"high": 3, "medium": 2, "low": 1},
    "customer_impact": {"high": 3, "medium": 2, "low": 1}
  }
}
