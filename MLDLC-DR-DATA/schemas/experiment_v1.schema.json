{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Schema v1",
  "type": "object",
  "required": ["name", "hypothesis", "parameters", "results"],
  "properties": {
    "name": {"type": "string"},
    "hypothesis": {"type": "string"},
    "parameters": {"type": "object"},
    "results": {"type": "object"},
    "schema_version": {"type": "string", "enum": ["v1"]},
    "lineage_id": {"type": "string"},
    "risk_level": {"type": "string", "enum": ["RED", "YELLOW", "GREEN"]}
  }
}
